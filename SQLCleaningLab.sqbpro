FROM evCars

SELECT PowerTrain, count (PowerTrain)
FROM evCars
group by PowerTrain

SELECT PowerTrain
FROM evCars
WHERE PowerTrain = 'AWD'

SELECT PowerTrain
FROM evCars
WHERE PowerTrain = 'RWD'

SELECT PowerTrain
FROM evCars
WHERE PowerTrain = 'FWD'

UPDATE evCars
SET PowerTrain = 'AWD'
WHERE PowerTrain = 'All Wheel Drive'

UPDATE evCars
SET PowerTrain = 'RWD'
WHERE PowerTrain = 'Rear Wheel Drive'

UPDATE evCars
SET PowerTrain = 'FWD'
WHERE PowerTrain = 'Front Wheel Drive'

</sql><sql name="SQL 1* (1)*">select *
from evCars

SELECT Efficiency, rtrim(Efficiency, ' Wh/km')
FROM evCars

UPDATE evCars
SET Efficiency = rtrim(Efficiency, ' Wh/km')

ALTER TABLE evCars
RENAME Efficiency TO EfficiencyWhKm


SELECT TopSpeedkmh, round((TopSpeedkmh * 0.621371), 1)
FROM evCars


UPDATE evCars
SET EfficiencyWhKm = round((EfficiencyWhKm * 0.621371), 1)

ALTER TABLE evCars
RENAME EfficiencyWhKm TO EfficiencyWHperKM</sql><sql name="all queries for HW*">--I used this select statement to verify all my QUERies
select *
from evCars 
# 1
SELECT Accel, rtrim(accel, ' sec')
FROM evCars

UPDATE evCars
SET Accel = rtrim(accel, '  sec')

ALTER TABLE evCars
RENAME Accel TO AccelSec

SELECT avg(AccelSec) as AVGAccel
FROM evCars

# 2.1
SELECT TopSpeed, rtrim(TopSpeed, ' km/h')
FROM evCars

UPDATE evCars
SET TopSpeed = rtrim(TopSpeed, ' km/h')

UPDATE evCars
SET TopSpeed = round((TopSpeed * 0.621371), 1)

ALTER TABLE evCars
RENAME TopSpeed TO TopSpeedMPH

# 3
SELECT Range, rtrim(Range, ' km')
FROM evCars

UPDATE evCars
SET Range = rtrim(Range, ' km')

UPDATE evCars
SET Range = round((Range * 0.621371), 1)

ALTER TABLE evCars
RENAME Range TO RangeMiles

# 4.1
SELECT Efficiency, rtrim(Efficiency, ' Wh/km')
FROM evCars

UPDATE evCars
SET Efficiency = rtrim(Efficiency, ' Wh/km')

UPDATE evCars
SET Efficiency = round((Efficiency * 0.621371), 1)

ALTER TABLE evCars
RENAME Efficiency TO EfficiencyWHperKM

# 4.1
SELECT FastCharge, rtrim(FastCharge, ' km/h')
FROM evCars

UPDATE evCars
SET FastCharge = rtrim(FastCharge, ' km/h')

UPDATE evCars
SET FastCharge = round((FastCharge * 0.621371), 1)

ALTER TABLE evCars
RENAME FastCharge TO OneHourFastChargeMiles

#5
SELECT RapidCharge
FROM evCars

SELECT RapidCharge, count (RapidCharge)
FROM evCars
group by RapidCharge

SELECT RapidCharge
FROM evCars
WHERE RapidCharge = 'No'

SELECT RapidCharge
FROM evCars
WHERE RapidCharge = 'Yes'

UPDATE evCars
SET RapidCharge = 'No'
WHERE RapidCharge = 'Rapid charging not possible'

UPDATE evCars
SET RapidCharge = 'Yes'
WHERE RapidCharge = 'Rapid charging possible'

For the purpose of this exercise, if the car's RapidCharge value equals 'Rapid charging possible' then I want you to change the value to 'Yes'
If the RapidCharge value equals 'Rapid charging not possible' then I want you to change the value to 'No'.

#6

SELECT PowerTrain, count (PowerTrain)
FROM evCars
group by PowerTrain

SELECT PowerTrain
FROM evCars
WHERE PowerTrain = 'AWD'

SELECT PowerTrain
FROM evCars
WHERE PowerTrain = 'RWD'

SELECT PowerTrain
FROM evCars
WHERE PowerTrain = 'FWD'

UPDATE evCars
SET PowerTrain = 'AWD'
WHERE PowerTrain = 'All Wheel Drive'

UPDATE evCars
SET PowerTrain = 'RWD'
WHERE PowerTrain = 'Rear Wheel Drive'

UPDATE evCars
SET PowerTrain = 'FWD'
WHERE PowerTrain = 'Front Wheel Drive'</sql><current_tab id="2"/></tab_sql></sqlb_project>
